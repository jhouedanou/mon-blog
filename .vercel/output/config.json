{
  "version": 3,
  "overrides": {
    "index.html": {
      "path": ""
    }
  },
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/builds/meta/(.*)"
    },
    {
      "headers": {
        "Content-Type": "text/xml; charset=UTF-8",
        "Cache-Control": "public, max-age=600, must-revalidate",
        "X-Sitemap-Prerendered": "2025-06-13T18:49:31.199Z"
      },
      "src": "/__sitemap__/index.xml"
    },
    {
      "headers": {
        "Content-Type": "text/xml; charset=UTF-8",
        "Cache-Control": "public, max-age=600, must-revalidate",
        "X-Sitemap-Prerendered": "2025-06-13T18:49:31.199Z"
      },
      "src": "/__sitemap__/fr-FR.xml"
    },
    {
      "headers": {
        "Content-Type": "text/xml; charset=UTF-8",
        "Cache-Control": "public, max-age=600, must-revalidate",
        "X-Sitemap-Prerendered": "2025-06-13T18:49:31.199Z"
      },
      "src": "/__sitemap__/en-US.xml"
    },
    {
      "headers": {
        "cache-control": "public, max-age=1, immutable"
      },
      "src": "/_nuxt/builds/(.*)"
    },
    {
      "status": 307,
      "headers": {
        "Location": "/sitemap_index.xml"
      },
      "src": "/sitemap.xml"
    },
    {
      "headers": {
        "Content-Type": "application/xslt+xml"
      },
      "src": "/sitemap.xsl"
    },
    {
      "headers": {
        "Content-Type": "text/xml; charset=UTF-8",
        "Cache-Control": "public, max-age=600, must-revalidate",
        "X-Sitemap-Prerendered": "2025-06-13T18:49:31.199Z"
      },
      "src": "/sitemap_index.xml"
    },
    {
      "status": 307,
      "headers": {
        "Location": "/__sitemap__/index.xml"
      },
      "src": "/index-sitemap.xml"
    },
    {
      "status": 307,
      "headers": {
        "Location": "/__sitemap__/fr-FR.xml"
      },
      "src": "/fr-FR-sitemap.xml"
    },
    {
      "status": 307,
      "headers": {
        "Location": "/__sitemap__/en-US.xml"
      },
      "src": "/en-US-sitemap.xml"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/(.*)"
    },
    {
      "src": "/_nuxt/builds/meta(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt/builds(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    }
  ]
}