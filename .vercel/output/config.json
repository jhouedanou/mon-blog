{
  "version": 3,
  "overrides": {
    "index.html": {
      "path": ""
    }
  },
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/builds/meta/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=1, immutable"
      },
      "src": "/_nuxt/builds/(.*)"
    },
    {
      "headers": {
        "Content-Type": "application/xslt+xml"
      },
      "src": "/sitemap.xsl"
    },
    {
      "status": 307,
      "headers": {
        "Location": "/sitemap_index.xml"
      },
      "src": "/sitemap.xml"
    },
    {
      "status": 307,
      "headers": {
        "Location": "/__sitemap__/index.xml"
      },
      "src": "/index-sitemap.xml"
    },
    {
      "status": 307,
      "headers": {
        "Location": "/__sitemap__/fr-FR.xml"
      },
      "src": "/fr-FR-sitemap.xml"
    },
    {
      "status": 307,
      "headers": {
        "Location": "/__sitemap__/en-US.xml"
      },
      "src": "/en-US-sitemap.xml"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/(.*)"
    },
    {
      "src": "/_nuxt/builds/meta(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt/builds(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/__sitemap__/index.xml",
      "dest": "/__sitemap__/index.xml?url=$url"
    },
    {
      "src": "/__sitemap__/fr-FR.xml",
      "dest": "/__sitemap__/fr-FR.xml?url=$url"
    },
    {
      "src": "/__sitemap__/en-US.xml",
      "dest": "/__sitemap__/en-US.xml?url=$url"
    },
    {
      "src": "/__nuxt_error",
      "dest": "/__nitro"
    },
    {
      "src": "/sitemap_index.xml",
      "dest": "/sitemap_index.xml?url=$url"
    },
    {
      "src": "/(.*)",
      "dest": "/__nitro"
    }
  ]
}